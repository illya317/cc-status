# DeepSeek balance (required for ¥ balance display)
DEEPSEEK_API_KEY=sk-xxx

# Kimi Code quota (required for quota bar)
# https://kimi-k2.ai/user-center/api-keys → API key
KIMI_API_KEY=sk-kimi-...

# MiniMax quota (required for quota bar)
MINIMAX_API_KEY=sk-xxx

# GLM / Zhipu quota (required for quota bar)
# Default base URL: https://open.bigmodel.cn/api/anthropic
ANTHROPIC_AUTH_TOKEN=your-token
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
